# =============================================================================
# AI Pipeline Evaluation - Environment Variables
# =============================================================================
# Copy this to .env and fill in the key for your chosen provider.
# You only need ONE of these — whichever matches config.llm.provider

# --- HuggingFace (default) ---
HUGGINGFACE_API_KEY=hf_your-huggingface-token-here

# --- OpenAI (switch to this by changing config) ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Ollama (no key needed, just run ollama locally) ---
# No env var required for Ollama

# --- Compatible APIs (Groq, Together, DeepSeek) ---
# GROQ_API_KEY=gsk_your-groq-key
# TOGETHER_API_KEY=your-together-key
# DEEPSEEK_API_KEY=your-deepseek-key

# --- Optional ---
# For Confident AI platform integration (DeepEval reporting)
CONFIDENT_AI_API_KEY=

# GitHub token for accessing private repos
GITHUB_TOKEN=
